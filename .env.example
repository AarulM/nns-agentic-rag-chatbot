# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.
#   cp .env.example .env
#
# Everything here is a resource identifier, not a secret. The one real
# credential (the Cognito client secret) lives in agents/gateway_secrets.py,
# which is gitignored separately.
#
# Run `python agents/env_check.py` after filling this in — it tells you
# exactly which values are still missing or wrong.


# --- Region and credentials ----------------------------------------------
# No default. us-east-1 for commercial AWS, us-gov-west-1 for GovCloud.
# The partition (aws vs aws-us-gov) is derived from this, so every ARN the
# code builds follows automatically.
AWS_REGION=us-east-1

# Which local AWS profile to use (`aws configure list-profiles`).
# GovCloud is a SEPARATE ACCOUNT in a separate partition — a commercial
# profile cannot reach it. env_check.py catches that mismatch explicitly.
AWS_PROFILE=


# --- Model selection ------------------------------------------------------
# ollama  = free, local, for testing (default if unset)
# bedrock = real Claude via AWS Bedrock, costs money per request
MODEL_PROVIDER=ollama

# Only used when MODEL_PROVIDER=ollama.
OLLAMA_MODEL_ID=llama3.1:8b

# Optional override. Leave blank to use the per-region default:
#   commercial -> global.anthropic.claude-haiku-4-5-20251001-v1:0
#   GovCloud   -> us-gov.anthropic.claude-sonnet-4-5-20250929-v1:0
# List what your region actually has:
#   aws bedrock list-inference-profiles \
#     --query "inferenceProfileSummaries[].inferenceProfileId"
BEDROCK_MODEL_ID=


# --- From `cdk deploy` outputs -------------------------------------------
# These change on every teardown/rebuild. The stack prints them; paste here.
KNOWLEDGE_BASE_ID=
DATA_SOURCE_ID=
DOCS_BUCKET=
GUARDRAIL_ID=
# DRAFT tracks the latest deployed stack config, so guardrail edits take
# effect on the next `cdk deploy` with no version bookkeeping.
GUARDRAIL_VERSION=DRAFT


# --- Multimodal file uploads ---------------------------------------------
# Staging bucket for uploads and Bedrock Data Automation output. Kept
# separate from DOCS_BUCKET so a failed extraction never leaves a partial
# artifact in the Knowledge Base's data source. Create it yourself:
#   aws s3api create-bucket --bucket <name> --region $AWS_REGION
UPLOAD_BUCKET=

# Optional. Blank uses the AWS-managed default BDA project, which handles
# all four modalities with no setup. Set these only if you build your own
# project or need a non-default inference profile.
BDA_PROJECT_ARN=
BDA_PROFILE_ARN=


# --- PII redaction (local, no AWS cost) ----------------------------------
# Extracted text is scrubbed of PII (names, SSNs, emails, phone numbers,
# cards, ...) BEFORE it is written to S3 or the Knowledge Base. The engine
# is Microsoft Presidio running locally — pure CPU, not an AWS call, so it
# adds no billing. Needs a spaCy English model installed once:
#   python -m spacy download en_core_web_lg
#
# On by default; these are all optional overrides:
#   PII_REDACTION=off            disable entirely (writes raw text — not advised)
#   PII_ENTITIES=PERSON,US_SSN   comma list to override which types are redacted
#   PII_SCORE_THRESHOLD=0.35     lower = redact more aggressively
#   PII_SPACY_MODEL=en_core_web_lg   NER model (falls back to en_core_web_sm)
PII_REDACTION=on


# --- From setup_gateway.py output ----------------------------------------
# Needed for the Operations tools (SMAX tickets, calendar, Jabber).
GATEWAY_URL=
COGNITO_DOMAIN=
COGNITO_CLIENT_ID=


# --- From create_memory.py -----------------------------------------------
# Fixed name, no random suffix — nothing to re-paste after a rebuild.
MEMORY_TABLE=NnsChatbotMemory


# --- Billing guardrail (setup_billing_alarm.py) --------------------------
# Where the AWS Budget alert emails go. Required to run setup_billing_alarm.py.
# No confirmation click needed — Budgets emails the address directly. Leave
# blank here; put your real address in .env (gitignored, never committed).
BILLING_ALERT_EMAIL=
# Monthly cost budget in USD. Alerts fire at 50% / 90% actual and 100%
# forecast. Default is 10 if unset.
BILLING_BUDGET_LIMIT=10
